
# ─── macOS residuals ──────────────────────────────────────────
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ─── Windows residuals ────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ─── Credentials & secrets — NEVER commit ─────────────────────
# ODIN session config (Figma PAT + last frame URL)
.odin-session
# Generic secrets / tokens
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.*
*_secret*
*_token*
*_pat*
*.pat

# ─── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
package-lock.json
*.log

# ─── Generated component output (SAGA) ───────────────────────
src/

# ─── Storybook config & build output ─────────────────────────
.storybook/
storybook-static/

# ─── Hermes memory — volatile state + rebuildable caches ──────
# Committed: episodes.jsonl, lessons.jsonl, memory-adapter.md
# Ignored:   live run state + caches + synced KB/token clones
.github/prompts/.hermes/state/*
!.github/prompts/.hermes/state/.gitkeep
.github/prompts/.hermes/cache/*
!.github/prompts/.hermes/cache/.gitkeep
